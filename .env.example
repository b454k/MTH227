# Copy this file to .env and fill in only the keys you need.

# Required for LLM-powered follow-up/report generation.
OPENAI_API_KEY=

# Optional; defaults to gpt-4o-mini when not set in the app code.
OPENAI_MODEL=gpt-4o-mini

# Required when rebuilding Chroma collections with the Hugging Face embedding model.
HF_TOKEN=

# Optional path overrides. Leave blank for normal project-relative paths.
CAREER_RAG_DATA_DIR=
ONET_DUCKDB_PATH=
ONET_DOCUMENTS_PATH=
ONET_SECTION_DOCUMENTS_PATH=
ONET_SUPPLEMENTAL_DOCUMENTS_PATH=
RESEARCH_DOCUMENTS_PATH=
CHROMA_ONET_DIR=
CHROMA_RESEARCH_DIR=
CHROMA_AI_IMPACT_DIR=
ANTHROPIC_EVIDENCE_PATH=
PROFILE_RESULT_PATH=
